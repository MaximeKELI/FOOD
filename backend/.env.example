# Copie ce fichier en .env et adapte les valeurs.
SECRET_KEY=change-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,10.0.2.2

# PostgreSQL
DB_NAME=food_db
DB_USER=food_user
DB_PASSWORD=food_pass
DB_HOST=127.0.0.1
DB_PORT=5432

# CORS
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Production
SERVE_MEDIA=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# S3 (optionnel — laisse vide pour stockage local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-3
AWS_S3_CUSTOM_DOMAIN=

# Paiements (Wave / Orange — à remplir quand tu auras les clés)
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_WEBHOOK_SECRET=
PAYMENT_CALLBACK_BASE_URL=http://127.0.0.1:8000
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# FCM push (backend — chemin vers le JSON service account Firebase)
FIREBASE_CREDENTIALS_PATH=
