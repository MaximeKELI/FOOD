# Copie ce fichier en .env et adapte les valeurs.
SECRET_KEY=change-me-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,10.0.2.2

# PostgreSQL
DB_NAME=food_db
DB_USER=food_user
DB_PASSWORD=food_pass
DB_HOST=127.0.0.1
DB_PORT=5432

# CORS
CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Production
SERVE_MEDIA=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# S3 / MinIO (optionnel — laisse USE_S3=False pour stockage local)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_USE_SSL=True
AWS_S3_REGION_NAME=eu-west-3
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=False
AWS_S3_SIGNATURE_VERSION=s3v4

REDIS_URL=
SOCKET_EMIT_URL=
SOCKET_INTERNAL_SECRET=socket-internal-dev
DELIVERIES_ENABLED=False

# Paiements
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_WEBHOOK_SECRET=
PAYMENT_CALLBACK_BASE_URL=http://127.0.0.1:8000

# FCM push (backend — chemin vers le JSON service account Firebase)
FIREBASE_CREDENTIALS_PATH=
